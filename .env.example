DATABASE_URL=postgresql://openhermit:dev@localhost:5433/openhermit
DATABASE_URL_TEST=postgresql://openhermit:dev@localhost:5433/openhermit_test

# Sandbox backend API keys (only needed when using the corresponding type)
E2B_API_KEY=
DAYTONA_API_KEY=

# --- Vexa meeting transcription (see docs/vexa-meetings.md) ---
# Base URL of the self-hosted Vexa REST API gateway.
VEXA_BASE_URL=http://localhost:18056
# Vexa MCP server endpoint registered with OpenHermit (provides the mcp__vexa__* tools).
# The port/path depend on your Vexa deployment — confirm against its compose.
VEXA_MCP_URL=http://localhost:18056/mcp
# Vexa API key (mint via the Vexa Admin API). Convenient for ops/probing here,
# but the load-bearing copy is the per-agent secret used to expand
# ${{VEXA_API_KEY}} in the MCP server headers:
#   hermit config secrets set VEXA_API_KEY <token> --agent <agentId>
VEXA_API_KEY=
# Shared secret authenticating Vexa -> OpenHermit webhooks. Set the SAME value
# as the "Vexa Meetings" channel secret on the agent and in Vexa's
# PUT /user/webhook.
VEXA_WEBHOOK_SECRET=
