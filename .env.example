DATABASE_URL=postgresql://openhermit:dev@localhost:5433/openhermit
DATABASE_URL_TEST=postgresql://openhermit:dev@localhost:5433/openhermit_test

# Sandbox backend API keys (only needed when using the corresponding type)
E2B_API_KEY=
DAYTONA_API_KEY=

# --- Vexa meeting transcription (see docs/vexa-meetings.md) ---
# Self-hosted Vexa REST API gateway. Default Docker Compose port is 8056.
VEXA_BASE_URL=http://localhost:8056
# Vexa MCP server endpoint (default Compose port 18888). Registered with
# OpenHermit to provide the mcp__vexa__* tools. Confirm the path against your
# Vexa MCP service (Streamable HTTP).
VEXA_MCP_URL=http://localhost:18888/mcp
# Vexa API key (mint via Vexa's Admin API). The load-bearing copy is the
# per-agent secret used to expand ${{VEXA_API_KEY}} in the MCP server headers:
#   hermit config secrets set VEXA_API_KEY <token> --agent <agentId>
VEXA_API_KEY=
# Shared secret authenticating Vexa -> OpenHermit webhooks. Set the SAME value
# as the "Vexa Meetings" channel secret on the agent AND in Vexa via
# PUT /user/webhook (webhook_secret).
VEXA_WEBHOOK_SECRET=
